# Copy this file to .env.local and fill in your actual Supabase project values.
# Find these under: Supabase Dashboard -> Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY - never expose this to the browser. Used only in app/api/* routes
# to create student accounts when an admin approves an enrollment request.
# Find it under: Settings -> API -> Project API keys -> service_role (click "Reveal")
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
